
@model IEnumerable<Day55.Models.Employee>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="text-center text-decoration-underline text-uppercase">
    <h1>Dashboard</h1>
</div>


<div class="alert alert-primary">
    @ViewBag.announcement;
</div>

@if(ViewData["status"]=="Active")
{
    <h5 class="text-end">Server Status - @ViewData["status"]</h5>
}

<h3 class="alert alert-success">Department - @ViewData["dept"]</h3>

<table class="table table-hover table-secondary table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Position</th>
            <th>Salary</th>
        </tr>
    </thead>

    <tbody class=" table table-dark">
        @foreach(var v in Model)
        {
            <tr>
                <td>@v.Name</td>
                <td>@v.Position</td>
                <td>@v.Salary</td>
            </tr>
        }
    </tbody>
</table>