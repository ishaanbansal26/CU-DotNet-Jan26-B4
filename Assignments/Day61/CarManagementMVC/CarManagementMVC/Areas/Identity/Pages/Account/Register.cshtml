@page
@model RegisterModel
@{
	ViewData["Title"] = "Register";
}
<style>


	html, body {
		height: 100%;
		margin: 0;
		font-family: Arial, Helvetica, sans-serif;
	}

	body {
		/* background: linear-gradient(to bottom, #3f51f7 50%, #c7d2fe 50%); */
		/* background: #c7d2fe; */
		background: linear-gradient(135deg, #e9ecf7, #dfe3f0);
	}

	/* wrapper same as login */
	.register-wrapper {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: calc(100vh - 70px - 70px);
		padding-bottom:22px;
	}

	/* card same size as login */
	.register-card {
		background: white;
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 15px 40px rgba(0,0,0,0.2);
		width: 900px;
		max-width: 100%;
	}

	/* left side spacing */
	.left-side {
		padding: 40px;
	}

	/* right side image area */
	.right-side {
		background: #f5f6fa;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-direction: column;
		padding: 30px;
	}

		.right-side img {
			/* max-width: 100%;
			height: auto;
			border-radius: 8px; */
			width: 300px;
			height: auto;
		}

	/* title same as login */
	h1 {
		font-size: 28px;
		font-weight: 700;
		margin-bottom: 5px;
	}

	h2 {
		font-size: 18px;
		font-weight: 600;
		margin-bottom: 10px;
	}

	h3 {
		font-size: 16px;
	}

	label {
		font-size: 14px;
	}

	input {
		font-size: 14px;
	}

	/* button same as login */
	#registerSubmit {
		background-color: #3f51f7;
		border: none;
		font-size: 16px;
	}

		#registerSubmit:hover {
			background-color: #2f3de0;
		}
</style>

<div class="register-wrapper">

	
	<div class="register-card">

		<div class="row g-0">


			<!-- LEFT SIDE -->
			<div class="col-md-6 left-side">


				<h1>@ViewData["Title"]</h1>


				<div class="row">

					<div class="col-md-12">

						<form id="registerForm"
							  asp-route-returnUrl="@Model.ReturnUrl"
							  method="post">

							<h2>Create a new account.</h2>
							<hr />

							<div asp-validation-summary="ModelOnly"
								 class="text-danger"
								 role="alert"></div>


							<div class="form-floating mb-3">
								<input asp-for="Input.Email"
									   class="form-control"
									   placeholder="name@example.com" />
								<label asp-for="Input.Email">Email</label>
								<span asp-validation-for="Input.Email"
									  class="text-danger"></span>
							</div>


							<div class="form-floating mb-3">
								<input asp-for="Input.Password"
									   class="form-control"
									   placeholder="password" />
								<label asp-for="Input.Password">Password</label>
								<span asp-validation-for="Input.Password"
									  class="text-danger"></span>
							</div>


							<div class="form-floating mb-3">
								<input asp-for="Input.ConfirmPassword"
									   class="form-control"
									   placeholder="password" />
								<label asp-for="Input.ConfirmPassword">
									Confirm Password
								</label>
								<span asp-validation-for="Input.ConfirmPassword"
									  class="text-danger"></span>
							</div>


							<button id="registerSubmit"
									type="submit"
									class="w-100 btn btn-primary">
								Register
							</button>

						</form>

					</div>


					<!-- KEEP THIS PART EXACTLY -->
					<div class="col-md-12 mt-4">

						<section>

							<h3>Use another service to register.</h3>
							<hr />

							@{
								if ((Model.ExternalLogins?.Count ?? 0) == 0)
								{
									<div>
										<p>
											There are no external authentication services configured.
										</p>
									</div>
								}
								else
								{
									<form id="external-account"
										  asp-page="./ExternalLogin"
										  asp-route-returnUrl="@Model.ReturnUrl"
										  method="post"
										  class="form-horizontal">

										<div>

											<p>

												@foreach (var provider in Model.ExternalLogins!)
												{
													<button type="submit"
															class="btn btn-primary me-2"
															name="provider"
															value="@provider.Name">

														@provider.DisplayName

													</button>
												}

											</p>

										</div>

									</form>
								}
							}

						</section>

					</div>


				</div>

			</div>


			<!-- RIGHT SIDE -->
			<div class="col-md-6 right-side">

				<img src="/images/Carlogo-removebg-preview.png" />

				<h5 class="mt-3">
					Create your account
				</h5>

				<p class="text-muted text-center">
					Start managing your cars easily
				</p>

			</div>


		</div>

	</div>
	

</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}
