@{
    ViewData["Title"] = "Home Page";
}

<div class="p-5 mb-4 bg-light rounded-3 text-center border border-3">
    <div class="container-fluid py-5">
        <h1 class="display-5 fw-bold">
            Hello, User! Welcome to our Company Portal
        </h1>
        <p class="col-md-8 fs-4 mx-auto">
            Learn About Our Company
        </p>
        <a href="/Home/About" class="btn btn-outline-dark btn-lg">Learn More</a>
    </div>
</div>

<div class="container">
    <div class="row">

        <div class="col-md-4">
            <div class="card">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSmTbpcqXLz8N88_CBuYgJNGlGMzeN2tVpyRQ&s" class="card-img-top" alt="Company Building" style="height: 200px;
                    object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title">Products</h5>
                    <p class="card-text">Our Company Provides different Products</p>
                    <a href="/Products/Index" class="btn btn-outline-dark" >Go To Prodcuts</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTKxVdOPEwpIkSVijHUINUWq5Btl43iFbMrjg&s" class="card-img-top" alt="Team Work" style="height: 200px;
                    object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title">Our Services</h5>
                    <p class="card-text">Check Out our Services</p>
                    <a href="/Services/Index" class="btn btn-outline-dark">Go To Services</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <img src="https://static.vecteezy.com/system/resources/thumbnails/020/804/109/small/communication-and-technology-concept-hand-putting-wooden-block-cube-symbol-telephone-email-address-website-page-contact-us-or-e-mail-marketing-contact-us-in-customer-support-concept-photo.jpg" class="card-img-top" alt="Office" style="height: 200px;
                    object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title">Contact Us</h5>
                    <p class="card-text">Contact Us for more Information.</p>
                    <a href="/Contact" class="btn btn-outline-dark">Contact</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>