@model List<CategorySummaryDto>

@{
    ViewData["Title"] = "Category Summary";
    ViewData["HideFooter"] = true;
}

<div class="container py-5">
    
    @* <div class="text-center mb-5">
        <h2 class="fw-bold display-6">Category Summary</h2>
        <p class="text-muted">Real-time inventory and pricing overview</p>
    </div> *@

    @* The container itself often generates a scrollbar if the table is wide *@
    <div class="table-responsive custom-table-container shadow-lg no-scrollbar">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Category Name</th>
                    <th>Product Count</th>
                    <th>Average Price</th>
                    <th class="pe-4">Most Expensive Product</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold text-dark">
                            @item.CategoryName
                        </td>
                        <td>
                            <span class="badge bg-soft-dark text-dark border">
                                @item.ProductCount Items
                            </span>
                        </td>
                        <td class="fw-bold text-success">
                            ₹@item.AvgPrice
                        </td>
                        <td class="pe-4 italic-product">
                            @item.MostExpensiveProduct
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-center mt-5">
        <a href="/Categories" class="btn btn-dark px-5 py-2 rounded-pill shadow">
            Back to Categories
        </a>
    </div>
</div>

<style>
    /* 1. THE NUCLEAR SCROLLBAR HIDER */
    
    /* Targets the whole page AND the specific table container */
    html, body, .no-scrollbar, .table-responsive {
        -ms-overflow-style: none !important; /* IE and Edge */
        scrollbar-width: none !important; /* Firefox */
    }

        html::-webkit-scrollbar,
        body::-webkit-scrollbar,
        .no-scrollbar::-webkit-scrollbar,
        .table-responsive::-webkit-scrollbar {
            display: none !important; /* Chrome, Safari, Opera */
            width: 0 !important;
            height: 0 !important;
        }

    /* 2. TABLE STYLING */
    .custom-table-container {
        border-radius: 20px;
        background: #fff;
        border: 1px solid rgba(0,0,0,0.05);
    }

    thead {
        background-color: #212529;
        color: #ffffff;
    }

        thead th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
            padding: 20px !important;
            border: none !important;
        }

    tbody tr:hover {
        background-color: rgba(0, 0, 0, 0.02);
    }

    tbody td {
        padding: 18px 20px !important;
        border-bottom: 1px solid #f0f0f0;
    }

    .bg-soft-dark {
        background-color: #f8f9fa;
        padding: 6px 12px;
        border-radius: 8px;
    }

    .italic-product {
        color: #555;
        font-style: italic;
    }

    /* Global layout fixes */
    html, body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        background-color: #fdfdfd;
    }
</style>