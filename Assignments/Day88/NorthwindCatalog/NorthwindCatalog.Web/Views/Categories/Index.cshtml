@model List<CategoryDto>

@{
    ViewData["Title"] = "Product Categories";
    ViewData["HideFooter"] = true; // This is the trigger
}

<div class="container py-4">

    <h2 class="text-center fw-bold mb-4">
        Product Categories
    </h2>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="card border-0 shadow-lg h-100 category-card">

                    <div class="overflow-hidden">
                        <img src="@item.ImageUrl"
                             class="card-img-top category-img"
                             alt="category image" />
                    </div>

                    <div class="card-body text-center">

                        <h5 class="card-title fw-semibold">
                            @item.CategoryName
                        </h5>

                        <a href="/Products/ByCategory/@item.CategoryId"
                               class="btn btn-dark w-100 mt-3">
                            View Products
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>
</div>

<style>
    /* Card styling */
    .category-card {
        border-radius: 15px;
        transition: all 0.3s ease;
    }

        .category-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.2);
        }

    /* Image */
    .category-img {
        height: 180px;
        width: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .category-card:hover .category-img {
        transform: scale(1.05);
    }

    /* Title */
    .card-title {
        font-size: 1.1rem;
        color: #333;
    }

    /* GLOBAL SAFE FIX */
    html, body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }
</style>