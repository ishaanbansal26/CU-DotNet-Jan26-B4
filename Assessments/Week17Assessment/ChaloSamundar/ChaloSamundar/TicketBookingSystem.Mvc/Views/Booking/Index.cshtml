@model TicketBookingSystem.Mvc.ViewModels.BookingViewModel

<style>
    :root {
        --brand: #32B096;
        --brand-dark: #279078;
        --ink: #0f172a;
        --muted: #64748b;
    }

    body { background: #f7f8fa; }

    .booking-page h5 { color: var(--ink); letter-spacing: -.2px; }
    .booking-page .text-muted { color: var(--muted) !important; }

    .booking-page .card {
        border: 1px solid #eceef2 !important;
        border-radius: 16px !important;
        box-shadow: 0 4px 14px rgba(10,37,64,.06) !important;
    }

    .booking-page .form-control,
    .booking-page .form-select {
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: .7rem .9rem;
        font-size: .95rem;
    }
    .booking-page .form-control:focus,
    .booking-page .form-select:focus {
        border-color: var(--brand);
        box-shadow: 0 0 0 3px rgba(50,176,150,.15);
    }

    .booking-page .btn-brand {
        background: linear-gradient(135deg, var(--brand), var(--brand-dark));
        color: #fff; border: none; font-weight: 700;
        border-radius: 12px; padding: .85rem 1rem;
        letter-spacing: .3px; transition: all .2s ease;
    }
    .booking-page .btn-brand:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 22px rgba(50,176,150,.35);
        color: #fff;
    }

    .booking-page .btn-brand-outline {
        background: #fff; color: var(--brand);
        border: 1.5px solid var(--brand);
        border-radius: 10px; font-weight: 600;
        padding: .45rem .9rem;
    }
    .booking-page .btn-brand-outline:hover {
        background: var(--brand); color: #fff;
    }

    .booking-page .price-accent { color: var(--brand) !important; }
</style>

<div class="container my-5 booking-page">
    <div class="row g-4">

        <!-- LEFT: Booking Form -->
        <div class="col-lg-8">

            <!-- Journey Info -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Journey Details</h5>

                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-1 text-muted">Route</p>
                            <p class="fw-semibold">
                                @Model.SourcePort (@Model.SourcePortCode)
                                →
                                @Model.DestinationPort (@Model.DestinationPortCode)
                            </p>
                        </div>

                        <div class="col-md-6">
                            <p class="mb-1 text-muted">Journey</p>
                            <p class="fw-semibold">@Model.JourneyName</p>
                        </div>

                        <div class="col-md-6">
                            <p class="mb-1 text-muted">Embarkation</p>
                            <p class="fw-semibold">@Model.Embarkation.ToString("dd MMM yyyy")</p>
                        </div>

                        <div class="col-md-6">
                            <p class="mb-1 text-muted">Disembarkation</p>
                            <p class="fw-semibold">@Model.Disembarkation.ToString("dd MMM yyyy")</p>
                        </div>

                        <div class="col-md-6">
                            <p class="mb-1 text-muted">Cabin</p>
                            <p class="fw-semibold">@Model.CabinType</p>
                        </div>

                        <div class="col-md-6">
                            <p class="mb-1 text-muted">Nights</p>
                            <p class="fw-semibold">@Model.Nights</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Passenger Section -->
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0">Passengers</h5>
                        <button type="button" class="btn-brand-outline btn-sm" onclick="addPassenger()">
                            + Add Passenger
                        </button>
                    </div>

                    <form asp-action="Create" method="post">
                        <div id="passengerContainer">

                            @for (int i = 0; i < Model.Passengers.Count; i++)
                            {
                                <div class="border rounded p-3 mb-3">
                                    <div class="row g-3">

                                        <div class="col-md-4">
                                            <label class="form-label">Name</label>
                                            <input asp-for="Passengers[@i].Name" class="form-control" />
                                        </div>

                                        <div class="col-md-3">
                                            <label class="form-label">Age</label>
                                            <input asp-for="Passengers[@i].Age" type="number" class="form-control" />
                                        </div>

                                        <div class="col-md-3">
                                            <label class="form-label">Gender</label>
                                            <select asp-for="Passengers[@i].Gender" class="form-select">
                                                <option value="">Select</option>
                                                <option>Male</option>
                                                <option>Female</option>
                                            </select>
                                        </div>

                                        <div class="col-md-2 d-flex align-items-end">
                                            <button type="button" class="btn btn-danger w-100"
                                                    onclick="removePassenger(this)">
                                                Remove
                                            </button>
                                        </div>

                                    </div>
                                </div>
                            }

                        </div>

                        <button type="submit" class="btn-brand w-100 mt-3 py-2">
                            Confirm Booking
                        </button>
                    </form>
                </div>
            </div>

        </div>

        <!-- RIGHT: Summary -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                <div class="card-body">

                    <h5 class="fw-bold mb-3">Booking Summary</h5>

                    <div class="mb-2 d-flex justify-content-between">
                        <span class="text-muted">Cabin</span>
                        <span>@Model.CabinType</span>
                    </div>

                    <div class="mb-2 d-flex justify-content-between">
                        <span class="text-muted">Passengers</span>
                        <span id="passengerCount">@Model.Passengers.Count</span>
                    </div>

                    <div class="mb-3 d-flex justify-content-between">
                        <span class="text-muted">Duration</span>
                        <span>@Model.Nights Nights</span>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">Total Fare</span>
                        <span class="fw-bold price-accent">
                            ₹@Model.TotalFare
                        </span>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

<script>
    function addPassenger() {
        const container = document.getElementById('passengerContainer');
        const index = container.children.length;

        const html = `
        <div class="border rounded p-3 mb-3">
            <div class="row g-3">
                <div class="col-md-4">
                    <label>Name</label>
                    <input name="Passengers[${index}].Name" class="form-control"/>
                </div>
                <div class="col-md-3">
                    <label>Age</label>
                    <input type="number" name="Passengers[${index}].Age" class="form-control"/>
                </div>
                <div class="col-md-3">
                    <label>Gender</label>
                    <select name="Passengers[${index}].Gender" class="form-select">
                        <option>Male</option>
                        <option>Female</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="button" class="btn btn-danger w-100"
                        onclick="removePassenger(this)">Remove</button>
                </div>
            </div>
        </div>`;

        container.insertAdjacentHTML('beforeend', html);
        updateCount();
    }

    function removePassenger(btn) {
        btn.closest('.border').remove();
        updateCount();
    }

    function updateCount() {
        const count = document.getElementById('passengerContainer').children.length;
        document.getElementById('passengerCount').innerText = count;
    }
</script>
<script>
    async function confirmBooking() {
        const form = document.getElementById('bookingForm');
        const formData = new FormData(form);

        try {
            const response = await fetch('@Url.Action("Create", "Booking")', {
                method: 'POST',
                body: formData
            });

            // If controller returns JSON with bookingId
            const result = await response.json();

            if (result.success) {
                // ✅ Redirect to payment page with bookingId
                window.location.href = `/Payment/Index?bookingId=${result.bookingId}`;
            } else {
                showError(result.message || 'Booking failed. Please try again.');
            }

        } catch (err) {
            showError('Something went wrong. Please try again.');
        }
    }

    function showError(msg) {
        const box = document.getElementById('errorBox');
        box.textContent = msg;
        box.classList.remove('d-none');
    }

    function addPassenger() {
        const container = document.getElementById('passengerContainer');
        const index = container.children.length;

        const html = `
        <div class="border rounded p-3 mb-3">
            <div class="row g-3">
                <div class="col-md-4">
                    <label>Name</label>
                    <input name="Passengers[${index}].Name" class="form-control"/>
                </div>
                <div class="col-md-3">
                    <label>Age</label>
                    <input type="number" name="Passengers[${index}].Age" class="form-control"/>
                </div>
                <div class="col-md-3">
                    <label>Gender</label>
                    <select name="Passengers[${index}].Gender" class="form-select">
                        <option>Male</option>
                        <option>Female</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="button" class="btn btn-danger w-100"
                        onclick="removePassenger(this)">Remove</button>
                </div>
            </div>
        </div>`;

        container.insertAdjacentHTML('beforeend', html);
        updateCount();
    }

    function removePassenger(btn) {
        btn.closest('.border').remove();
        updateCount();
    }

    function updateCount() {
        const count = document.getElementById('passengerContainer').children.length;
        document.getElementById('passengerCount').innerText = count;
    }
</script>