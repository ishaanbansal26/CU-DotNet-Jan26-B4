@model IEnumerable<FinTrack_pro.Models.Account>

@{
    ViewData["Title"] = "Accounts";
}

<h1>Accounts</h1>

@if (TempData["Success"] != null)
{
    <div class="toast show position-fixed top-0 end-0 m-3">
        <div class="toast-header bg-success text-white">
            <strong class="me-auto">Success</strong>
        </div>
        <div class="toast-body">
            @TempData["Success"]
        </div>
    </div>
}

<p>
    <a asp-action="Create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.AccountNumber)
            </th>

            <th>
                @Html.DisplayNameFor(model => model.AccountHolder)
            </th>

            <th>
                @Html.DisplayNameFor(model => model.Balance)
            </th>

            <!-- ✅ ADDED -->
            <th>
                Transactions
            </th>

            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>
                    @Html.DisplayFor(modelItem => item.AccountNumber)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.AccountHolder)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.Balance)
                </td>

                <!-- ✅ ADDED -->
                <td>
                    @if (item.Transactions != null && item.Transactions.Count > 0)
                    {
                        <ul>
                            @foreach (var t in item.Transactions)
                            {
                                <li>
                                    @t.Description - @t.Amount - @t.Date.ToShortDateString()
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span>No transactions</span>
                    }

                </td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.AccountId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.AccountId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.AccountId">Delete</a>
                </td>

            </tr>
        }

    </tbody>
</table>