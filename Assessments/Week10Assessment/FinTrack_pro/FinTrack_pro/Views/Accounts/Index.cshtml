@model IEnumerable<FinTrack_pro.Models.Account>

@{
    ViewData["Title"] = "Accounts";
}

<h1>Accounts</h1>

@if (TempData["Success"] != null)
{
    <div class="toast show position-fixed top-0 end-0 m-3">
        <div class="toast-header bg-success text-white">
            <strong class="me-auto">Success</strong>
        </div>
        <div class="toast-body">
            @TempData["Success"]
        </div>
    </div>
}

<p>
    <a asp-action="Create">Create New</a>
</p>

<table class="table ">
    <thead class="table-dark">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.AccountNumber)
            </th>

            <th>
                @Html.DisplayNameFor(model => model.AccountHolder)
            </th>

            <th>
                @Html.DisplayNameFor(model => model.Balance)
            </th>

            <th>
                Transactions
            </th>

            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>
                    @Html.DisplayFor(modelItem => item.AccountNumber)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.AccountHolder)
                </td>

                <td>
                    @String.Format("₹{0:N2}", item.Balance)
                </td>

                <td>
                    <div class="d-flex gap-2">
                        <!-- Toggle button for transactions accordion -->
                        <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#transactionsCollapse_@item.AccountId" aria-expanded="false" aria-controls="transactionsCollapse_@item.AccountId">
                            View Transactions
                        </button>
                        <a asp-controller="Transactions" asp-action="Create" asp-route-accountId="@item.AccountId" class="btn btn-sm btn-success">Add Transaction</a>
                    </div>
                </td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.AccountId" class="btn btn-sm btn-primary me-1">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.AccountId" class="btn btn-sm btn-info text-white me-1">Details</a>
                    <form asp-action="Delete" asp-route-id="@item.AccountId" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this account?');">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>

            </tr>

            <tr class="collapse-row">
                <td colspan="5" class="p-0 border-0">
                    <div class="collapse" id="transactionsCollapse_@item.AccountId">
                        <div class="card card-body">
                            @if (item?.Transactions != null && item.Transactions.Count > 0)
                            {
                                // Show transactions in chronological order (oldest -> newest)
                                var transactions = item.Transactions.OrderBy(t => t.Date).ThenBy(t => t.Id).ToList();

                                // Use Account.Balance as the initial balance (starting balance)
                                double runningBalance = (double)item.Balance;

                                <table class="table table-sm mb-0">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Description</th>
                                            <th>Category</th>
                                            <th>Amount</th>
                                            <th>Remaining Balance</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @* <tr class="table-primary">
                                            <td></td>
                                            <td><strong>Opening Balance</strong></td>
                                            <td></td>
                                            <td></td>
                                            <td><strong>@runningBalance.ToString("C")</strong></td>
                                        </tr> *@

                                        @foreach (var t in transactions)
                                        {
                                            bool isDebit = string.Equals(t.Category ?? string.Empty, "Debit", System.StringComparison.OrdinalIgnoreCase);
                                            // Apply transaction to running balance: debit subtracts, credit adds
                                            runningBalance += isDebit ? -t.Amount : t.Amount;

                                            <tr>
                                                <td>@t.Date.ToShortDateString()</td>
                                                <td>@t.Description</td>
                                                <td>@t.Category</td>
                                                <td class="@(isDebit ? "text-danger" : "text-success")">@((isDebit) ? ("-" + t.Amount.ToString("C")) : t.Amount.ToString("C"))</td>
                                                <td>@runningBalance.ToString("C")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div>No transactions</div>
                            }
                        </div>
                    </div>
                </td>
            </tr>
        }

    </tbody>
</table>