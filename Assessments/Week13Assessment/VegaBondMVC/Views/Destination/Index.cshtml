
@model IEnumerable<VagaBondAPI.Models.Destination>

@{
    ViewData["Title"] = "Destinations";
}

<h1>Destinations</h1>

@* <p>
    <a asp-controller="Destination" asp-action="Create" class="btn btn-primary">Create New</a>
</p> *@

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No destinations found.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>City</th>
                <th>Country</th>
                <th>Rating</th>
                <th>Last Visited</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.CityName</td>
                <td>@item.Country</td>
                <td>@item.Rating</td>
                <td>@item.LastVisited.ToString("yyyy-MM-dd")</td>
                <td>
                    <a asp-controller="Destination" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    @* <a asp-controller="Destination" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Edit</a>
                    <a asp-controller="Destination" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a> *@
                </td>
            </tr>
        }
        </tbody>
    </table>
}
