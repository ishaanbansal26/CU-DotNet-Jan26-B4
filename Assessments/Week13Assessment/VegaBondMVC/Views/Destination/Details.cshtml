
@model VagaBondAPI.Models.Destination

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Destination</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">City</dt>
        <dd class="col-sm-10">@Model.CityName</dd>

        <dt class="col-sm-2">Country</dt>
        <dd class="col-sm-10">@Model.Country</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Rating</dt>
        <dd class="col-sm-10">@Model.Rating</dd>

        <dt class="col-sm-2">Last Visited</dt>
        <dd class="col-sm-10">@Model.LastVisited.ToString("yyyy-MM-dd")</dd>
    </dl>

    <a asp-controller="Destination" asp-action="Index" class="btn btn-secondary">Back to list</a>
</div>
